# Copy to .env (gitignored) and fill in. Never commit real values — the repo is public.

# --- Database (Neon Postgres, project: dr-watch) ------------------------------
DATABASE_URL=            # POOLED connection string (host contains "-pooler"), sslmode=require
DATABASE_URL_DIRECT=     # DIRECT connection string (same host WITHOUT "-pooler") — alembic only

# --- LLM providers (free tiers) — needed later, when the pipeline lands -------
GEMINI_API_KEY=
GROQ_API_KEY=
